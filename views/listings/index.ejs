<% layout("layouts/boilerplate") %>

<body>
    <div id="filters">
        <div class="filter">
            <a href="/listings?category=trending" class="category-item <%= activeCategory === 'trending' ? 'active' : '' %>">
            <div><i class="fa-solid fa-fire"></i></div>
           <p>Trending</p>
           </a>
        </div>

        <div class="filter">
            <a href="/listings?category=rooms" class="category-item <%= activeCategory === 'rooms' ? 'active' : '' %>">
            <div><i class="fa-solid fa-bed"></i></div>
           <p>Rooms</p>
           </a>
        </div>

        <div class="filter">
            <a href="/listings?category=iconic-cities" class="category-item <%= activeCategory === 'iconic-cities' ? 'active' : '' %>">
            <div><i class="fa-solid fa-mountain-city"></i></div>
           <p>Iconic Cities</p>
           </a>
        </div>

        <div class="filter">
            <a href="/listings?category=mountains" class="category-item <%= activeCategory === 'mountains' ? 'active' : '' %>">
            <div><i class="fa-solid fa-mountain"></i></div>
           <p>Mountains</p>
           </a>
        </div>

        <div class="filter">
            <a href="/listings?category=castles" class="category-item <%= activeCategory === 'castles' ? 'active' : '' %>">
            <div><i class="fa-brands fa-fort-awesome"></i></div>
           <p>Castles</p>
           </a>
        </div>

        <div class="filter">
            <a href="/listings?category=pools" class="category-item <%= activeCategory === 'pools' ? 'active' : '' %>">
            <div><i class="fa-solid fa-person-swimming"></i></div>
           <p>Amazing Pools</p>
           </a>
        </div>
        
        <div class="filter">
            <a href="/listings?category=arctic" class="category-item <%= activeCategory === 'arctic' ? 'active' : '' %>">
            <div><i class="fa-regular fa-snowflake"></i></div>
           <p>Arctic</p>
           </a>
        </div>

        <div class="filter">
            <a href="/listings?category=camping" class="category-item <%= activeCategory === 'camping' ? 'active' : '' %>">
            <div><i class="fa-solid fa-campground"></i></div>
           <p>Camping</p>
           </a>
        </div>

        <div class="filter">
            <a href="/listings?category=farms" class="category-item <%= activeCategory === 'farms' ? 'active' : '' %>">
            <div><i class="fa-solid fa-cow"></i></div>
           <p>Farms</p>
            </a>
        </div>

         <div class="filter">
            <a href="/listings?category=domes" class="category-item <%= activeCategory === 'domes' ? 'active' : '' %>">
            <div><i class="fa-solid fa-igloo"></i></div>
           <p>Domes</p>
           </a>
        </div>

        <div class="filter">
            <a href="/listings?category=boats" class="category-item <%= activeCategory === 'boats' ? 'active' : '' %>">
            <div><i class="fa-solid fa-ship"></i></div>
           <p>Boats</p>
           </a>
        </div>
           

        <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display taxes after total</label>
            </div>
        </div>
    </div>

     <%- include("../includes/flash") %>

    <% if(noResults) { %>
        <div class="alert alert-danger alert-dismissible fade show mt-3 no-results" role="alert">
            No results found for "<%= searchQuery || activeCategory %>" 
            <button type="button" class="btn-close" onclick="window.location.href='/listings'" aria-label="Close"></button>
        </div>
    <% } %>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for(let listing of allListings){ %>
        <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card col listing-card">
            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height:20rem"/>
            <div class="card-img-overlay"></div>
            <div class="card-body text-center">
            <p class="card-text"> 
           <b> <%= listing.title %></b></br> 
            &#8377;<%= listing.price.toLocaleString('en-IN') %> / night 
            <i class="tax-info">&nbsp; &nbsp; +18% GST</i>
            </p>
            </div>
        </div>
        </a>
     <% } %>
    </div>
    
</body>
